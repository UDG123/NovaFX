# ============================================================
# NovaFX Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_DESK_CRYPTO=
TG_DESK_FOREX=
TG_DESK_STOCKS=
TG_DESK_COMMODITIES=
TG_DESK_FUTURES=
TG_DESK1=
TG_DESK2=
TG_DESK3=
TG_DESK4=
TG_DESK5=
TG_DESK6=
TG_PORTFOLIO=
TG_SYSTEM=

# --- Data Providers ---
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
ALPHAVANTAGE_API_KEY=
CRYPTOCOMPARE_API_KEY=

# --- Alpaca (Paper Trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- NovaFX App ---
WEBHOOK_SECRET=change-me
DEFAULT_RISK_PCT=1.0
ACCOUNT_BALANCE=10000
SIGNAL_ENGINE_ENABLED=true
SIGNAL_ENGINE_INTERVAL_MINUTES=15
PORT=8000

# --- Dispatcher ---
DISPATCHER_URL=http://localhost:8000
CONFLUENCE_WINDOW_SEC=3600
CONFLUENCE_MIN_SOURCES=2
CONFLUENCE_MIN_CONFIDENCE=0.6

# --- Scanner ---
SCAN_INTERVAL=300

# --- Database (optional — PostgreSQL on Railway) ---
DATABASE_URL=
